# Files
AUTOEDGE_DATABASE_PATH=/var/lib/autoedge-licensing/autoedge.db

# Local listener. Caddy/nginx should terminate HTTPS and proxy to this address.
AUTOEDGE_BIND_HOST=127.0.0.1
AUTOEDGE_BIND_PORT=8788
AUTOEDGE_PUBLIC_BASE_URL=https://licenses.example.com

# Admin sessions. Generate with: openssl rand -base64 48
AUTOEDGE_ADMIN_COOKIE_SECRET=replace-with-at-least-32-random-characters
AUTOEDGE_COOKIE_SECURE=true
AUTOEDGE_ADMIN_SESSION_HOURS=12

# Whop webhook auth. Prefer WHOP_WEBHOOK_SECRET from Whop Standard Webhooks.
WHOP_WEBHOOK_SECRET=

# Optional fallback for non-Whop server-to-server testing.
AUTOEDGE_WHOP_BEARER_TOKEN=

# Trader client behavior
AUTOEDGE_LICENSE_CHECK_INTERVAL_SECONDS=21600
AUTOEDGE_GRACE_PERIOD_SECONDS=259200
AUTOEDGE_RATE_LIMIT_PER_MINUTE=60
