# Copy to /etc/autoedge-backup.env, fill in the selected OFF-HOST restic
# repository, protect it with root:root 0600, and never commit the real file.
#
# Examples:
# RESTIC_REPOSITORY=s3:s3.example.com/autoedge-production
# RESTIC_REPOSITORY=sftp:backup@example.com:/srv/restic/autoedge-production
RESTIC_REPOSITORY=replace-with-off-host-restic-repository

# Generate a long random repository password in /etc/autoedge-restic-password.
# Store a second copy in an external password manager/recovery vault. Losing this
# password makes the encrypted backups permanently unrecoverable.
RESTIC_PASSWORD_FILE=/etc/autoedge-restic-password
RESTIC_CACHE_DIR=/var/cache/autoedge-restic

# Add only the credentials required by the selected backend. These S3 names are
# examples; remove them when another backend is used.
AWS_ACCESS_KEY_ID=replace-with-backup-only-access-key
AWS_SECRET_ACCESS_KEY=replace-with-backup-only-secret-key

# Snapshot and retention settings.
AUTOEDGE_BACKUP_DATABASE_PATH=/var/lib/autoedge-licensing/autoedge.db
AUTOEDGE_BACKUP_SNAPSHOT_DIR=/var/backups/autoedge-licensing/current
AUTOEDGE_BACKUP_KEEP_DAILY=7
AUTOEDGE_BACKUP_KEEP_WEEKLY=5
AUTOEDGE_BACKUP_KEEP_MONTHLY=12
